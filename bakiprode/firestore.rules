rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cualquier usuario autenticado puede leer usuarios y resultados
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Pronósticos: cada usuario solo escribe los suyos, todos pueden leer
    match /predictions/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Resultados oficiales: solo lectura para usuarios autenticados
    // Escritura solo desde backend (Firebase Admin SDK) o manualmente desde consola
    match /results/{docId} {
      allow read:  if request.auth != null;
      allow write: if false; // cambiar a regla de admin si usás Cloud Functions
    }
  }
}
